<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>دۆخی داواکاری - پابجی ڕیکرویت</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="particles"></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">
        <img src="/images/Mask.svg" alt="MASK TEAM" height="45">
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/">سەرەکی</a>
        <a href="/calculate">📊 حسابکەر</a>
        <a href="/videos">🎬 ڤیدیۆ</a>
        <a href="/apply">داواکاری بنێرە</a>
        <a href="/status" class="active">دۆخی ببینە</a>
        <a href="/staff">ستاف</a>
      </div>
    </div>
  </nav>

  <section class="status-section">
    <div class="container">
      <div class="status-container">
        <div class="form-header">
          <h1>دۆخی داواکارییەکەت <span class="accent">ببینە</span></h1>
          <p>ئیمەیڵەکەت بنووسە بۆ بینینی دۆخ و نامەکانی ڕیکرووتیاران.</p>
        </div>

        <form action="/status" method="GET" class="status-form">
          <div class="form-group">
            <input type="email" name="email" placeholder="ئیمەیڵەکەت بنووسە..." required value="<%= typeof player !== 'undefined' && player ? player.email : '' %>">
            <button type="submit" class="btn btn-primary tilt-3d">ببینە</button>
          </div>
        </form>

        <% if (typeof player !== 'undefined' && player) { %>
          <div class="status-result perspective-container">
            <div class="status-header">
              <h2><%= player.ign %></h2>
              <span class="badge badge-<%= player.status %>"><%= player.status === 'pending' ? 'چاوەڕوانی' : player.status === 'reviewed' ? 'پشکنین کراوە' : player.status === 'accepted' ? 'پەسەند کراوە' : 'ڕەت کراوە' %></span>
            </div>
            <div class="status-details">
              <div class="detail"><span>ڕۆڵ:</span> <%= player.role %></div>
              <div class="detail"><span>ئاست:</span> <%= player.tier %></div>
              <div class="detail"><span>KD:</span> <%= player.kd || 'N/A' %></div>
              <div class="detail"><span>بردنەوە:</span> <%= player.wins || 'N/A' %></div>
              <div class="detail"><span>نێردرا:</span> <%= new Date(player.created_at).toLocaleDateString('ckb') %></div>
            </div>

            <% if (replies.length > 0) { %>
              <div class="replies-section">
                <h3>نامەکانی ڕیکرووتیاران</h3>
                <% replies.forEach(function(reply) { %>
                  <div class="reply-card">
                    <div class="reply-header">
                      <strong><%= reply.admin_name %></strong>
                      <span><%= new Date(reply.created_at).toLocaleDateString('ckb') %></span>
                    </div>
                    <p><%= reply.message %></p>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="no-replies">هێشتا هیچ نامەیەک نییە. کاتێک نوێکاری هەبوو ئاگادارت دەکەینەوە.</p>
            <% } %>
          </div>
        <% } else if (typeof player !== 'undefined' && !player) { %>
          <div class="alert alert-error">هیچ داواکارییەک بەم ئیمەیڵە نەدۆزرایەوە. دڵنیابە لە ڕاستی ئیمەیڵەکە یان <a href="/apply">داواکارییەکی نوێ بنێرە</a>.</div>
        <% } %>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© ٢٠٢٦ PUBG RECRUIT. هەموو مافەکان پارێزراون.</p>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
