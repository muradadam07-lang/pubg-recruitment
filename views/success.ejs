<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>داواکاری نێردرا - پابجی ڕیکرویت</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="particles"></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">
        <img src="/images/Mask.svg" alt="MASK TEAM" height="45">
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/">سەرەکی</a>
        <a href="/calculate">📊 حسابکەر</a>
        <a href="/videos">🎬 ڤیدیۆ</a>
        <a href="/apply">داواکاری بنێرە</a>
        <a href="/status">دۆخی ببینە</a>
        <a href="/staff">ستاف</a>
      </div>
    </div>
  </nav>

  <section class="success-section">
    <div class="container">
      <div class="success-card perspective-container">
        <div class="success-icon">✓</div>
        <h1>داواکارییەکەت <span class="accent">نێردرا!</span></h1>
        <p>داواکارییەکەت بە سەرکەوتوویی نێردرا. تیمی ڕیکرووتمان پڕۆفایلەکەت دەپشکنن و بە زووی پێوەندی پێوە دەکەین.</p>
        <div class="success-steps">
          <div class="step">
            <span class="step-num">١</span>
            <span>پشکنینی داواکاری</span>
          </div>
          <div class="step-connector"></div>
          <div class="step">
            <span class="step-num">٢</span>
            <span>هەڵسەنگاندنی شارەزایی</span>
          </div>
          <div class="step-connector"></div>
          <div class="step">
            <span class="step-num">٣</span>
            <span>تاقیکردنەوەی تیپ</span>
          </div>
          <div class="step-connector"></div>
          <div class="step">
            <span class="step-num">٤</span>
            <span>بەخێربێیت بۆ تیپ!</span>
          </div>
        </div>
        <div class="success-actions">
          <a href="/status" class="btn btn-primary tilt-3d">دۆخی داواکاری ببینە</a>
          <a href="/" class="btn btn-secondary tilt-3d">گەڕانەوە بۆ سەرەکی</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© ٢٠٢٦ PUBG RECRUIT. هەموو مافەکان پارێزراون.</p>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
