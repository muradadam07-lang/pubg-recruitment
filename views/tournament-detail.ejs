<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= tournament.name %> - پابجی ڕیکرویت</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body class="dashboard-page">
  <div class="particles"></div>
  <canvas id="scene-3d"></canvas>
  <div class="battle-bg"><div class="battle-grid"></div><div class="scan-line"></div></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo"><img src="/images/Mask.svg" alt="MASK TEAM" height="45"></a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <span class="admin-greeting">بەخێربێیت، <%= adminName %></span>
        <a href="/dashboard">داواکارییەکان</a>
        <a href="/dashboard/tournaments" class="nav-results">🏆 تورنمنتەکان</a>
        <a href="/dashboard/tournaments" class="btn-logout">→ گەڕانەوە</a>
        <a href="/logout" class="btn-logout">دەرچوون</a>
      </div>
    </div>
  </nav>

  <section class="results-page-section">
    <div class="container">
      <!-- Header -->
      <div class="results-header">
        <div class="results-title-group">
          <div class="results-badge"><%= tournament.status === 'active' ? 'LIVE' : 'FINISHED' %></div>
          <h1><%= tournament.name %></h1>
          <p><%= tournament.game_count %> game(s) • <%= leaderboard.length %> team(s)</p>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <button class="btn btn-primary tilt-3d" onclick="document.getElementById('addResultModal').classList.add('active')">+ ئەنجام</button>
          <button class="btn btn-secondary tilt-3d" onclick="document.getElementById('batchModal').classList.add('active')">📋 خستەی خێرا</button>
          <% if (tournament.status === 'active') { %>
            <form action="/dashboard/tournaments/<%= tournament.id %>/finish" method="POST" onsubmit="return confirm('تورنمنتەکە تەواو بکەیت؟')">
              <button type="submit" class="btn" style="background:var(--red);color:#fff;">🔚 تەواوکردن</button>
            </form>
          <% } %>
        </div>
      </div>

      <!-- LEADERBOARD -->
      <div class="leaderboard-section">
        <h2 class="section-subtitle">🏆 ڕیزبەندی <span class="accent">تورنمنت</span></h2>
        <div class="leaderboard-grid">
          <% if (leaderboard.length === 0) { %>
            <p style="color:var(--text-secondary);grid-column:1/-1;text-align:center;">هێشتا هیچ ئەنجامێک نییە</p>
          <% } %>
          <% leaderboard.forEach(function(t, i) { %>
            <div class="lb-card tilt-3d-glow <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '' %>">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                <div style="font-size:1.8rem;min-width:45px;text-align:center;">
                  <%= i === 0 ? '👑' : i === 1 ? '🥈' : i === 2 ? '🥉' : '#' + (i + 1) %>
                </div>
                <div style="flex:1;">
                  <div class="lb-ign" style="font-size:1.2rem;"><%= t.name %></div>
                </div>
                <div style="text-align:right;">
                  <div style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--accent);"><%= t.total_points %></div>
                  <div style="font-size:0.65rem;color:var(--text-secondary);letter-spacing:1px;">POINTS</div>
                </div>
              </div>
              <div style="display:flex;gap:16px;margin-bottom:8px;font-size:0.85rem;justify-content:center;">
                <span>💀 <strong style="color:var(--red);font-size:1.1rem;"><%= t.total_kills %></strong> kills</span>
                <span>🏅 Best #<strong style="color:var(--blue);font-size:1.1rem;"><%= t.best_placement %></strong></span>
                <span>📊 <strong><%= t.games_played %></strong> games</span>
              </div>
              <div class="lb-bar">
                <div class="lb-bar-fill" style="width:<%= leaderboard.length > 0 ? (t.total_points / Math.max(...leaderboard.map(x=>x.total_points)) * 100) : 0 %>%"></div>
              </div>
              <% if (i < 3) { %>
                <div style="text-align:center;margin-top:6px;font-family:var(--font-display);font-size:0.7rem;letter-spacing:2px;color:var(--accent);">
                  <%= i === 0 ? '🏆 #1 CHAMPION' : i === 1 ? '🥈 #2 RUNNER UP' : '🥉 #3 THIRD PLACE' %>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- RESULTS TABLE -->
      <div class="recent-section">
        <h2 class="section-subtitle">📋 هەموو <span class="accent">ئەنجامەکان</span></h2>
        <div class="table-container results-table-container">
          <table class="players-table results-table">
            <thead>
              <tr>
                <th>GAME</th>
                <th>TEAM</th>
                <th>پلە</th>
                <th>کووشت</th>
                <th>خاڵ</th>
                <th>کردار</th>
              </tr>
            </thead>
            <tbody>
              <% if (results.length === 0) { %>
                <tr><td colspan="6" class="empty-state">هیچ ئەنجامێک نییە</td></tr>
              <% } %>
              <% results.forEach(function(r) { %>
                <tr>
                  <td><span class="badge badge-pending">Game <%= r.game_number %></span></td>
                  <td style="font-weight:700;color:var(--accent);"><%= r.team_name %></td>
                  <td><span class="placement-badge">#<%= r.placement %></span></td>
                  <td class="stat-kills">+<%= r.kills %></td>
                  <td class="stat-points">+<%= r.points %></td>
                  <td>
                    <form action="/dashboard/tournaments/<%= tournament.id %>/delete-result/<%= r.id %>" method="POST" onsubmit="return confirm('سڕینەوە؟')">
                      <button type="submit" class="btn-delete-small">✕</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- MODAL: Add single result -->
  <div class="modal" id="addResultModal">
    <div class="modal-overlay" onclick="document.getElementById('addResultModal').classList.remove('active')"></div>
    <div class="modal-content tilt-3d-glow">
      <button class="modal-close" onclick="document.getElementById('addResultModal').classList.remove('active')">✕</button>
      <h2>ئەنجامی <span class="accent">نوێ</span></h2>
      <form action="/dashboard/tournaments/<%= tournament.id %>/add-result" method="POST">
        <div class="form-group">
          <label>تیم</label>
          <select name="team_id" required>
            <option value="">تیم هەڵبژێرە</option>
            <% teams.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>ژمارەی یاری</label>
            <input type="number" name="game_number" value="1" min="1" max="20">
          </div>
          <div class="form-group">
            <label>پلە (Placement)</label>
            <input type="number" name="placement" required placeholder="1">
          </div>
        </div>
        <div class="form-group">
          <label>کووشت (Kills)</label>
          <input type="number" name="kills" value="0">
        </div>
        <div style="background:var(--bg-secondary);border-radius:8px;padding:12px 16px;margin-bottom:16px;">
          <div style="font-size:0.85rem;color:var(--text-secondary);">
            📊 Points = <strong style="color:var(--accent);">Placement</strong> (1st=10, 2nd=6, 3rd=5, 4th=4, 5th=3, 6th=2, 7th=1, 8th=1) + <strong style="color:var(--accent);">Kills</strong> (1pt each)
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-full">تۆمارکردن</button>
      </form>
    </div>
  </div>

  <!-- MODAL: Batch import -->
  <div class="modal" id="batchModal">
    <div class="modal-overlay" onclick="document.getElementById('batchModal').classList.remove('active')"></div>
    <div class="modal-content tilt-3d-glow" style="max-width:600px;">
      <button class="modal-close" onclick="document.getElementById('batchModal').classList.remove('active')">✕</button>
      <h2>خستەی <span class="accent">خێرا</span></h2>
      <p style="color:var(--text-secondary);margin-bottom:10px;">فۆرمات: <strong>IGN (TOP#) (TOP#) kill (K1-K2)</strong> ← 2 games auto-created</p>
      <div style="background:var(--bg-secondary);padding:12px;border-radius:6px;font-family:monospace;font-size:0.85rem;margin-bottom:15px;color:var(--text-secondary);line-height:1.8;">
K88esp (TOP1) (TOP11) kill (13-3)<br>
ICTFepic (TOP2) (TOP3) kill (17-4)<br>
MASKclub (TOP3) (TOP7) kill (14-10)<br>
MASKitz (TOP4) (TOP2) kill (3-16)<br>
ICTFg (TOP6) (TOP1) kill (2-16)<br>
KV (TOP24) (TOP4) kill (0-1)<br>
MASKice (TOP16) (TOP5) kill (0-6)
      </div>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin-bottom:10px;">📌 <strong>kill (17-4)</strong> = 17 kills in Game 1 + 4 kills in Game 2</p>
      <form action="/dashboard/tournaments/<%= tournament.id %>/batch-results" method="POST">
        <div class="form-group">
          <label>داونیشانی ئەنجامەکان</label>
          <textarea name="batch_data" rows="8" required placeholder="K88esp (TOP1) (TOP11) kill (13-3)"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">📥 هاوردەکردن</button>
      </form>
      <p style="color:var(--text-secondary);font-size:0.8rem;margin-top:10px;">تیمە نوێیەکان خۆکارانە دروست دەکرێن</p>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
