<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>داشبۆرد - پابجی ڕیکرویت</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body class="dashboard-page">
  <div class="particles"></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">
        <img src="/images/Mask.svg" alt="MASK TEAM" height="45">
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <span class="admin-greeting">بەخێربێیت، <%= adminName %></span>
        <a href="/dashboard">داواکارییەکان</a>
        <a href="/dashboard/tournaments" class="nav-results">🏆 تورنمنتەکان</a>
        <a href="/logout" class="btn-logout">دەرچوون</a>
      </div>
    </div>
  </nav>

  <section class="dashboard">
    <div class="container">
      <h1>داشبۆردی <span class="accent">ڕیکرووتمەنت</span></h1>

      <div class="stats-grid">
        <div class="stat-card total tilt-3d-glow">
          <span class="stat-value"><%= counts.total %></span>
          <span class="stat-label">کۆی داواکارییەکان</span>
        </div>
        <div class="stat-card pending tilt-3d-glow">
          <span class="stat-value"><%= counts.pending %></span>
          <span class="stat-label">چاوەڕوانی پشکنین</span>
        </div>
        <div class="stat-card reviewed tilt-3d-glow">
          <span class="stat-value"><%= counts.reviewed %></span>
          <span class="stat-label">پشکنین کراوە</span>
        </div>
        <div class="stat-card accepted tilt-3d-glow">
          <span class="stat-value"><%= counts.accepted %></span>
          <span class="stat-label">پەسەند کراوە</span>
        </div>
        <div class="stat-card rejected tilt-3d-glow">
          <span class="stat-value"><%= counts.rejected %></span>
          <span class="stat-label">ڕەت کراوە</span>
        </div>
      </div>

      <div class="filter-tabs">
        <a href="/dashboard?status=all" class="filter-tab <%= currentStatus === 'all' ? 'active' : '' %>">هەموو</a>
        <a href="/dashboard?status=pending" class="filter-tab <%= currentStatus === 'pending' ? 'active' : '' %>">چاوەڕوانی</a>
        <a href="/dashboard?status=reviewed" class="filter-tab <%= currentStatus === 'reviewed' ? 'active' : '' %>">پشکنین کراوە</a>
        <a href="/dashboard?status=accepted" class="filter-tab <%= currentStatus === 'accepted' ? 'active' : '' %>">پەسەند کراوە</a>
        <a href="/dashboard?status=rejected" class="filter-tab <%= currentStatus === 'rejected' ? 'active' : '' %>">ڕەت کراوە</a>
      </div>

      <div class="table-container">
        <table class="players-table">
          <thead>
            <tr>
              <th>IGN</th>
              <th>ناو</th>
              <th>ڕۆڵ</th>
              <th>ئاست</th>
              <th>KD</th>
              <th>دۆخ</th>
              <th>بەروار</th>
              <th>کردار</th>
            </tr>
          </thead>
          <tbody>
            <% if (players.length === 0) { %>
              <tr><td colspan="8" class="empty-state">هیچ داواکارییەک نەدۆزرایەوە</td></tr>
            <% } %>
            <% players.forEach(function(p) { %>
              <tr>
                <td class="ign-cell"><%= p.ign %></td>
                <td><%= p.name %></td>
                <td><%= p.role %></td>
                <td><%= p.tier %></td>
                <td><%= p.kd || '-' %></td>
                <td><span class="badge badge-<%= p.status %>"><%= p.status === 'pending' ? 'چاوەڕوانی' : p.status === 'reviewed' ? 'پشکنین کراوە' : p.status === 'accepted' ? 'پەسەند' : 'ڕەت کراوە' %></span></td>
                <td><%= new Date(p.created_at).toLocaleDateString('ckb') %></td>
                <td><a href="/dashboard/player/<%= p.id %>" class="btn-view">بینین</a></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
