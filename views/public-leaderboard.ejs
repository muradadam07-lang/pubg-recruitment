<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= tournament.name %> - Leaderboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="particles"></div>
  <canvas id="scene-3d"></canvas>
  <div class="battle-bg"><div class="battle-grid"></div><div class="scan-line"></div></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo"><img src="/images/Mask.svg" alt="MASK TEAM" height="45"></a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/">سەرەکی</a>
        <a href="/calculate">📊 حسابکەر</a>
        <a href="/videos">🎬 ڤیدیۆ</a>
        <a href="/apply">داواکاری بنێرە</a>
        <a href="/status">دۆخی ببینە</a>
        <a href="/staff">ستاف</a>
      </div>
    </div>
  </nav>

  <section class="results-page-section">
    <div class="container">
      <div style="text-align:center;margin-bottom:40px;">
        <div class="results-badge" style="margin-bottom:8px;">PUBG TOURNAMENT</div>
        <h1 style="font-family:var(--font-display);font-size:2.2rem;margin-bottom:8px;"><%= tournament.name %></h1>
        <p style="color:var(--text-secondary);">
          <%= tournament.game_count %> game(s) • <%= leaderboard.length %> team(s) •
          <span class="badge badge-<%= tournament.status === 'active' ? 'pending' : 'reviewed' %>"><%= tournament.status === 'active' ? 'LIVE' : 'FINISHED' %></span>
        </p>
      </div>

      <div class="liqui-table-wrap" style="max-width:<%= leaderboard.length > 0 && leaderboard[0].games && leaderboard[0].games.length > 1 ? 900 : 750 %>px;margin:0 auto;">
        <table class="liqui-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th class="col-team">تیم</th>
              <% if (leaderboard.length > 0 && leaderboard[0].games && leaderboard[0].games.length > 0) { %>
                <% leaderboard[0].games.forEach(function(g, gi) { %>
                  <th class="col-game">یاری <%= gi + 1 %></th>
                <% }); %>
              <% } %>
              <th class="col-kills">💀</th>
              <th style="text-align:center;">🏅 باشترین</th>
              <th class="col-total">خاڵ</th>
            </tr>
          </thead>
          <tbody>
            <% var maxPts = Math.max(...leaderboard.map(x=>x.total_points)); %>
            <% leaderboard.forEach(function(t, i) { %>
              <tr class="liqui-row <%= i === 0 ? 'row-gold' : i === 1 ? 'row-silver' : i === 2 ? 'row-bronze' : '' %>">
                <td class="col-rank">
                  <span class="rank-num <%= i < 3 ? 'rank-top' : '' %>"><%= i + 1 %></span>
                </td>
                <td class="col-team">
                  <div class="team-cell">
                    <div class="team-name"><%= t.name %></div>
                    <div class="team-sub"><%= t.total_kills %> kills</div>
                  </div>
                </td>
                <% if (t.games && t.games.length > 0) { %>
                  <% t.games.forEach(function(g) { %>
                    <td class="col-game">
                      <div class="game-result">
                        <span class="g-placement p-<%= g.placement %>"><%= g.placement %>.</span>
                        <span class="g-kills">+<%= g.kills %></span>
                        <span class="g-pts"><%= g.points %></span>
                      </div>
                    </td>
                  <% }); %>
                <% } %>
                <td class="col-kills">
                  <span class="kills-num"><%= t.total_kills %></span>
                </td>
                <td style="text-align:center;font-family:var(--font-display);font-weight:700;color:var(--blue);">#<%= t.best_placement %></td>
                <td class="col-total">
                  <span class="pts-num <%= i === 0 ? 'pts-first' : '' %>"><%= t.total_points %></span>
                  <div class="bar-wrap"><div class="bar-fill" style="width:<%= (t.total_points / maxPts * 100) %>%"></div></div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 PUBG RECRUIT. All rights reserved.</p>
    </div>
  </footer>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
