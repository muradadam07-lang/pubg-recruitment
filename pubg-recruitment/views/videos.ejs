<!DOCTYPE html>
<html lang="ckb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ڤیدیۆ - MASK TEAM</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="particles"></div>
  <canvas id="scene-3d"></canvas>
  <div class="battle-bg"><div class="battle-grid"></div><div class="scan-line"></div></div>
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo"><img src="/images/Mask.svg" alt="MASK TEAM" height="45"></a>
      <button class="menu-toggle" id="menuToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/">سەرەکی</a>
        <a href="/calculate">📊 حسابکەر</a>
        <a href="/videos" class="active">🎬 ڤیدیۆ</a>
        <a href="/apply">داواکاری بنێرە</a>
        <a href="/status">دۆخی ببینە</a>
        <a href="/staff">ستاف</a>
        <a href="/login" class="nav-admin">بەڕێوەبەر</a>
      </div>
    </div>
  </nav>

  <section class="results-page-section">
    <div class="container" style="max-width:960px;">
      <div style="text-align:center;margin-bottom:30px;">
        <div class="results-badge" style="margin-bottom:8px;">MASK TEAM</div>
        <h1 style="font-family:var(--font-display);font-size:2rem;margin-bottom:6px;">گەڕانی <span class="accent">ڤیدیۆ</span></h1>
        <p style="color:var(--text-secondary);">ڤیدیۆی PUBG لە یوتیوب بگەڕێ و سەیری بکە</p>
      </div>

      <!-- Search form -->
      <div class="form-container calc-form-glass" style="padding:24px;margin-bottom:30px;">
        <form id="videoSearch" style="display:flex;gap:12px;">
          <input type="text" id="searchQuery" placeholder="گەڕان ... e.g. MASK TEAM PUBG, PUBG moments, etc."
            style="flex:1;padding:14px 18px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;color:var(--text-primary);font-family:var(--font-body);font-size:1rem;outline:none;"
            value="<%= query %>">
          <button type="submit" class="btn btn-primary" style="padding:14px 28px;white-space:nowrap;">
            <span>🔍 گەڕان</span>
          </button>
        </form>
      </div>

      <!-- Results -->
      <div id="videoResults" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;">
        <% if (results && results.length > 0) { %>
          <% results.forEach(function(v) { %>
            <div class="vid-card tilt-3d-glow" onclick="playVideo('<%= v.id %>','<%= v.title.replace(/'/g,"\\'") %>')"
              style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;cursor:pointer;transition:all 0.3s;">
              <div style="position:relative;padding-top:56%;background:#000;overflow:hidden;">
                <img src="<%= v.thumbnail %>" alt="" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
                <div style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.8);padding:2px 8px;border-radius:4px;font-size:0.7rem;color:#fff;"><%= v.timestamp %></div>
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:50px;height:50px;border-radius:50%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;border:2px solid rgba(255,255,255,0.2);">
                  <span style="font-size:1.3rem;color:#fff;margin-left:3px;">▶</span>
                </div>
              </div>
              <div style="padding:14px;">
                <div style="font-family:var(--font-display);font-size:0.8rem;color:var(--accent);font-weight:700;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:6px;"><%= v.title %></div>
                <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--text-secondary);">
                  <span><%= v.author %></span>
                  <span><%= v.views ? new Intl.NumberFormat().format(v.views) + ' views' : '' %></span>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else if (results && results.length === 0) { %>
          <div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-secondary);">
            <div style="font-size:3rem;margin-bottom:12px;">🎬</div>
            <p>هیچ ڤیدیۆیەک نەدۆزرایەوە. وشەیەکی تر تاقی بکەرەوە.</p>
          </div>
        <% } else { %>
          <div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-secondary);">
            <div style="font-size:3rem;margin-bottom:12px;">🔍</div>
            <p>نوسینی گەڕان و کلیک لە گەڕان بکە بۆ دۆزینەوەی ڤیدیۆی PUBG</p>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Video player modal -->
  <div class="modal" id="videoModal">
    <div class="modal-overlay" onclick="closeVideo()"></div>
    <div class="modal-content" style="max-width:800px;padding:20px;">
      <button class="modal-close" onclick="closeVideo()">✕</button>
      <h2 id="videoTitle" style="font-family:var(--font-display);font-size:1rem;margin-bottom:16px;padding-right:30px;color:var(--accent);"></h2>
      <div style="position:relative;padding-top:56%;border-radius:8px;overflow:hidden;background:#000;">
        <div id="playerContainer" style="position:absolute;top:0;left:0;width:100%;height:100%;"></div>
      </div>
    </div>
  </div>

  <footer class="footer"><div class="container"><p>&copy; 2026 MASK TEAM. All rights reserved.</p></div></footer>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
  let player = null;

  function playVideo(id, title) {
    document.getElementById('videoTitle').textContent = title;
    document.getElementById('videoModal').classList.add('active');
    document.body.style.overflow = 'hidden';

    const container = document.getElementById('playerContainer');
    container.innerHTML = '';

    if (typeof YT !== 'undefined' && YT.Player) {
      initPlayer(id);
    } else {
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      const first = document.getElementsByTagName('script')[0];
      first.parentNode.insertBefore(tag, first);
      window.onYouTubeIframeAPIReady = () => initPlayer(id);
    }
  }

  function initPlayer(id) {
    if (player) { player.destroy(); }
    player = new YT.Player('playerContainer', {
      videoId: id,
      width: '100%', height: '100%',
      playerVars: { autoplay: 1, rel: 0, modestbranding: 1 }
    });
  }

  function closeVideo() {
    if (player) { player.stopVideo(); player.destroy(); player = null; }
    document.getElementById('videoModal').classList.remove('active');
    document.body.style.overflow = '';
  }

  // Search
  document.getElementById('videoSearch').addEventListener('submit', async function(e) {
    e.preventDefault();
    const q = document.getElementById('searchQuery').value.trim();
    if (!q) return;

    const resultsDiv = document.getElementById('videoResults');
    resultsDiv.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-secondary);">گەڕان ...</div>';

    try {
      const res = await fetch('/api/search-videos?q=' + encodeURIComponent(q));
      const data = await res.json();

      if (!data.results || data.results.length === 0) {
        resultsDiv.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-secondary);"><div style="font-size:3rem;margin-bottom:12px;">🎬</div><p>هیچ ڤیدیۆیەک نەدۆزرایەوە.</p></div>';
        return;
      }

      resultsDiv.innerHTML = data.results.map(v => `
        <div class="vid-card tilt-3d-glow" onclick="playVideo('${v.id}','${v.title.replace(/'/g,"\\'")}')"
          style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;cursor:pointer;transition:all 0.3s;">
          <div style="position:relative;padding-top:56%;background:#000;overflow:hidden;">
            <img src="${v.thumbnail}" alt="" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
            <div style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.8);padding:2px 8px;border-radius:4px;font-size:0.7rem;color:#fff;">${v.timestamp}</div>
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:50px;height:50px;border-radius:50%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;border:2px solid rgba(255,255,255,0.2);">
              <span style="font-size:1.3rem;color:#fff;margin-left:3px;">▶</span>
            </div>
          </div>
          <div style="padding:14px;">
            <div style="font-family:var(--font-display);font-size:0.8rem;color:var(--accent);font-weight:700;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:6px;">${v.title}</div>
            <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--text-secondary);">
              <span>${v.author}</span>
              <span>${v.views ? new Intl.NumberFormat().format(v.views) + ' views' : ''}</span>
            </div>
          </div>
        </div>
      `).join('');
    } catch (err) {
      resultsDiv.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--red);">هەڵە: ' + err.message + '</div>';
    }
  });
  </script>
</body>
</html>
